@import "tailwindcss";

@theme {
  --font-cinzel: 'Cinzel', serif;
  --font-cinzel-decorative: 'Cinzel Decorative', serif;
  --font-inter: 'Inter', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;

  --color-dark-bg: #050510;
  --color-dark-surface: #0a0a1a;
  --color-dark-card: #0d0d20;
  --color-dark-border: #1a1a3a;
  --color-neon-purple: #8b5cf6;
  --color-neon-cyan: #06b6d4;
  --color-neon-pink: #ec4899;
  --color-neon-blue: #3b82f6;

  --animate-float: float 6s ease-in-out infinite;
  --animate-float-delayed: float 6s ease-in-out infinite 2s;
  --animate-float-slow: float 8s ease-in-out infinite 1s;
  --animate-glow-pulse: glow-pulse 3s ease-in-out infinite;
  --animate-shimmer: shimmer 3s linear infinite;
  --animate-spin-slow: spin 20s linear infinite;
  --animate-rune-glow: rune-glow 4s ease-in-out infinite;
  --animate-scroll-indicator: scroll-indicator 2s ease-in-out infinite;
  --animate-border-glow: border-glow 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-15px) rotate(1deg); }
  66% { transform: translateY(-8px) rotate(-1deg); }
}

@keyframes glow-pulse {
  0%, 100% {
    filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.4));
    opacity: 1;
  }
  50% {
    filter: drop-shadow(0 0 40px rgba(139, 92, 246, 0.8));
    opacity: 0.95;
  }
}

@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

@keyframes rune-glow {
  0%, 100% {
    text-shadow: 0 0 10px rgba(139, 92, 246, 0.3);
    opacity: 0.4;
  }
  50% {
    text-shadow: 0 0 25px rgba(139, 92, 246, 0.8), 0 0 50px rgba(139, 92, 246, 0.4);
    opacity: 1;
  }
}

@keyframes border-glow {
  0%, 100% {
    border-color: rgba(139, 92, 246, 0.2);
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.05), inset 0 0 15px rgba(139, 92, 246, 0.02);
  }
  50% {
    border-color: rgba(139, 92, 246, 0.5);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.15), inset 0 0 30px rgba(139, 92, 246, 0.05);
  }
}

@keyframes scroll-indicator {
  0% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(10px); opacity: 0.3; }
  100% { transform: translateY(0); opacity: 1; }
}

@keyframes skill-fill {
  from { width: 0%; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes rotate-border {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: #050510;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #8b5cf6, #06b6d4);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #a78bfa, #22d3ee);
}

::selection {
  background: rgba(139, 92, 246, 0.3);
  color: #e2e8f0;
}

html {
  scroll-behavior: smooth;
}

body {
  background: #050510;
  color: #e2e8f0;
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
}

.glass {
  background: rgba(13, 13, 32, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(139, 92, 246, 0.12);
}

.text-glow-purple {
  text-shadow: 0 0 20px rgba(139, 92, 246, 0.5), 0 0 40px rgba(139, 92, 246, 0.3), 0 0 80px rgba(139, 92, 246, 0.15);
}

.text-glow-cyan {
  text-shadow: 0 0 20px rgba(6, 182, 212, 0.5), 0 0 40px rgba(6, 182, 212, 0.3);
}

.rune-text {
  font-family: 'Cinzel Decorative', serif;
  animation: rune-glow 4s ease-in-out infinite;
}

.card-glow {
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.card-glow:hover {
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 0 30px rgba(139, 92, 246, 0.12), 0 0 60px rgba(139, 92, 246, 0.05), inset 0 1px 0 rgba(139, 92, 246, 0.15);
  transform: translateY(-8px);
}

.gradient-text {
  background: linear-gradient(135deg, #a78bfa, #06b6d4, #ec4899, #a78bfa);
  background-size: 300% 300%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 4s linear infinite;
}

.shimmer-text {
  background: linear-gradient(90deg, #8b5cf6, #06b6d4, #ec4899, #8b5cf6);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3s linear infinite;
}

.mystical-border {
  position: relative;
}
.mystical-border::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: inherit;
  padding: 2px;
  background: linear-gradient(135deg, #8b5cf680, #06b6d440, #ec489940, #8b5cf680);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: border-glow 3s ease-in-out infinite;
}

.cursor-glow {
  pointer-events: none;
  position: fixed;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.06) 0%, transparent 70%);
  transform: translate(-50%, -50%);
  z-index: 9999;
  transition: opacity 0.3s;
}
